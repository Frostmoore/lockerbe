APP_NAME=Locker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------------
# PostgreSQL, non SQLite: serve la Row Level Security (piano §3.2).
# Due ruoli distinti, e la distinzione e' una misura di sicurezza, non stile:
#   locker_app   -> runtime. NON superuser, NON owner, NOBYPASSRLS: le policy lo governano.
#   locker_owner -> proprietario dello schema. Esegue SOLO le migration.
# Container: `docker compose up -d` (vedi docker-compose.yml).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=locker
DB_USERNAME=locker_app
DB_PASSWORD=locker_app
DB_OWNER_USERNAME=locker_owner
DB_OWNER_PASSWORD=locker_owner

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# predis: l'estensione phpredis non e' installata su questa macchina.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Locker (piano §16) -------------------------------------------------------
# Driver di pagamento e identita': mock finche' D1/D2 non sono sbloccate col cliente.
LOCKER_PAYMENT_DRIVER=mock
LOCKER_IDENTITY_DRIVER=mock
# Abilita i bottoni mock e l'emulatore device. MAI true in production.
LOCKER_MOCK_PANEL=true

# TTL dei comandi: e' il rischio #1 del sistema (piano §8). Un open accodato mentre
# l'armadio e' offline e consegnato tre ore dopo apre un vano pieno di roba alle 4
# del mattino. Ogni comando scade, e il device rifiuta quelli scaduti.
LOCKER_COMMAND_TTL_OPEN=30
LOCKER_RESERVATION_TTL=600
LOCKER_HEARTBEAT_TIMEOUT=90

# --- MQTT (piano §9) — usato da F5 --------------------------------------------
MQTT_HOST=127.0.0.1
MQTT_PORT=8883
MQTT_TLS=true
MQTT_CLIENT_ID=locker-server

# --- OTA (piano §13) — usato da F7 --------------------------------------------
OTA_CANARY_SIZE=1
OTA_HEALTH_TIMEOUT=600
